# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Allow Gradle wrapper jar (required to bootstrap builds)
!gradle/wrapper/gradle-wrapper.jar

# Local environment & secrets
.env
.env.local
application-local.properties

# Internal / private workshop materials (not shared in public repo)
internal/

# Python venv used only for local tooling (PDF extraction etc.)
.venv/
__pycache__/

# VS Code / Cursor workspace settings (keep shared ones tracked manually)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Gradle
.gradle
**/build/

# idea
.idea

# Mac
.DS_Store